    <NavigationView x:Name="AdminLayoutNavView" 
                    Grid.Row="0" 
                    Height="Auto"
                    IsPaneOpen="False"
                    PaneDisplayMode="Auto"
                    IsTabStop="False"
                    ItemInvoked="NavigationViewItem_Invoked">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Dashboard" 
                                Icon="Home" ToolTipService.ToolTip="Dashboard" 
                                Tag="PESYONG.Presentation.Views.Admin.DashboardPage"/>
            
            <NavigationViewItem Content="Meals" Icon="Contact" ToolTipService.ToolTip="Account">
                <NavigationViewItem.MenuItems>
                <NavigationViewItem Content="Catering Meals" 
                                        Icon="Mail" ToolTipService.ToolTip="Individual Meals" 
                                        Tag="PESYONG.Presentation.Views.Admin.Meals.MealPage"/>                    
                <NavigationViewItem Content="Catering Packages" 
                                        Icon="Calendar" ToolTipService.ToolTip="Meal Packages" 
                                        Tag="PESYONG.Presentation.Views.Admin.Meals.MealPackagePage"/>
                <NavigationViewItem Content="Customer Packages" 
                                        Icon="Calendar" ToolTipService.ToolTip="Meal Packages" 
                                        Tag="PESYONG.Presentation.Views.Admin.Meals.MealPackagePage"/>
                </NavigationViewItem.MenuItems>
            </NavigationViewItem>
            
            <NavigationViewItem Content="Logistics" Icon="Page2" ToolTipService.ToolTip="Logistics" SelectsOnInvoked="False">
                <NavigationViewItem.MenuItems>
                    <NavigationViewItem Content="Delivery" 
                                        Icon="OpenLocal" 
                                        ToolTipService.ToolTip="Deliveries" 
                                        Tag="PESYONG.Presentation.Views.Admin.Logistics.DeliveryPage"/>
                </NavigationViewItem.MenuItems>
            </NavigationViewItem>

            <NavigationViewItem Content="Transactions" Icon="Page2" ToolTipService.ToolTip="Document options" SelectsOnInvoked="False">
                <NavigationViewItem.MenuItems>
                    <NavigationViewItem Content="Orders" Icon="OpenLocal" ToolTipService.ToolTip="Upload file" Tag="SamplePage6"/>
                    <NavigationViewItem Content="Acknowledgement Receipts" Icon="NewFolder" ToolTipService.ToolTip="Create new" Tag="SamplePage5"/>
                </NavigationViewItem.MenuItems>
            </NavigationViewItem>

            <NavigationViewItem Content="Administration" Icon="Page2" ToolTipService.ToolTip="Document options" SelectsOnInvoked="False">
                <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Accounts" Icon="OpenLocal" ToolTipService.ToolTip="Upload file" Tag="SamplePage6"/>
                        <NavigationViewItem Content="Customers" Icon="OpenLocal" ToolTipService.ToolTip="Upload file" Tag="SamplePage6"/>
                        <NavigationViewItem Content="System Logs" Icon="NewFolder" ToolTipService.ToolTip="Create new" Tag="SamplePage5"/>
                </NavigationViewItem.MenuItems>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.AutoSuggestBox>
            <AutoSuggestBox QueryIcon="Find" AutomationProperties.Name="Search" />
        </NavigationView.AutoSuggestBox>

        <Frame x:Name="MainContentFrame" 
               Grid.Column="1"               
               VerticalAlignment="Stretch"/>
        </NavigationView>
    </Grid>
</UserControl>
