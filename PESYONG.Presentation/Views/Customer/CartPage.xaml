<Page
    x:Class="PESYONG.Presentation.Views.Customer.CartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:PESYONG.ApplicationLogic.Converters"
    xmlns:models="using:PESYONG.Domain.Entities"
    mc:Ignorable="d"
    Background="#FFFDF5">

    <Page.Resources>
        <local:PriceFormatConverter x:Key="PriceFormatConverter"/>
        <local:CartItemTypeToDisplayConverter x:Key="CartItemTypeToDisplayConverter"/>

        <Style x:Key="CartItemCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE5CC"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        

        <Style x:Key="QuantityButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FFB266"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="#FFF0E0" />
                                            <Setter Target="ButtonBorder.BorderBrush" Value="#FF9933" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="#FFE5CC" />
                                            <Setter Target="ButtonBorder.BorderBrush" Value="#FF6600" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="contentPresenter"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RemoveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="#FFE5E5"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF6600"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="#E65A00"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="#CC4D00"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="contentPresenter"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF6600"/>
            <Setter Property="BorderBrush" Value="#FF6600"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="#FFF0E0"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="#FFE5CC"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="contentPresenter"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeliveryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF6600"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DeliveryInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="PlaceholderForeground" Value="#A67C52"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFCC99"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="DeliveryRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#444444"/>
        </Style>

        <Style x:Key="DeliveryDatePickerStyle" TargetType="CalendarDatePicker">
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="Background" Value="#FFFDFB"/>
            <Setter Property="BorderBrush" Value="#FFCC99"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="DeliveryTimePickerStyle" TargetType="TimePicker">
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="Background" Value="#FFFDFB"/>
            <Setter Property="BorderBrush" Value="#FFCC99"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#A67C52"/>
        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#A67C52"/>
        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#A67C52"/>

        <SolidColorBrush x:Key="DatePickerPlaceholderForeground" Color="#A67C52"/>
        <SolidColorBrush x:Key="DatePickerPlaceholderForegroundPointerOver" Color="#A67C52"/>
        <SolidColorBrush x:Key="TimePickerPlaceholderForeground" Color="#A67C52"/>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="#FF6600" 
                CornerRadius="12" 
                Padding="20,15" 
                Margin="20,20,20,0">
            <StackPanel>
                <TextBlock x:Name="HeaderTitle" Text="My Cart" 
                          FontSize="36" 
                          FontWeight="Bold" 
                          Foreground="White"/>
                <TextBlock x:Name="HeaderSubtitle" 
                          FontSize="16" 
                          Foreground="#FFE5CC"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="20">
            <!-- Cart View -->
            <ScrollViewer x:Name="CartView" 
                         VerticalScrollBarVisibility="Auto"
                         Visibility="Visible">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Empty Cart State -->
                    <Border x:Name="EmptyCartPanel" 
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#FFF5E5"
                            BorderBrush="#FFE5CC"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="40"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                            <FontIcon Glyph="&#xE8C7;" 
                                     FontSize="72" 
                                     Foreground="#FFB266"/>
                            <TextBlock Text="Your cart is empty" 
                                      FontSize="24" 
                                      FontWeight="Bold" 
                                      Foreground="#FF6600"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="Start adding delicious items to your cart!" 
                                      FontSize="16" 
                                      Foreground="#666666"
                                      HorizontalAlignment="Center"/>
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Browse Packages"
                                    HorizontalAlignment="Center"
                                    Click="BrowsePackages_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Cart Items Grid -->
                    <Grid x:Name="CartItemsPanel" Grid.Column="0" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Cart Items List -->
                        <ItemsControl x:Name="CartItemsList" Grid.Row="0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CartItemCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Image -->
                                            <Border Grid.Column="0" 
                                                    Width="80" 
                                                    Height="80" 
                                                    CornerRadius="8"
                                                    Margin="0,0,12,0">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding Image}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>

                                            <!-- Item Details -->
                                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" 
                                                          Text="{Binding Name}" 
                                                          FontSize="16" 
                                                          FontWeight="Bold" 
                                                          Foreground="#FF6600"
                                                          TextWrapping="Wrap"/>

                                                <TextBlock Grid.Row="1" 
                                                          Text="{Binding Type, Converter={StaticResource CartItemTypeToDisplayConverter}}"
                                                          FontSize="12" 
                                                          Foreground="#666666"
                                                          Margin="0,2,0,4"/>

                                                <!-- Quantity Controls -->
                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Button Grid.Column="0" 
                                                            Style="{StaticResource QuantityButtonStyle}"
                                                            Tag="{Binding Id}"
                                                            Click="DecreaseQuantity_Click">
                                                        <FontIcon Glyph="&#xF8AB;" 
                                                                 FontSize="12" 
                                                                 Foreground="#FF6600"/>
                                                    </Button>

                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding Quantity}"
                                                               Width="40"
                                                               TextAlignment="Center"
                                                               FontWeight="Bold"
                                                               Foreground="#FF6600"
                                                               FontSize="14"
                                                               VerticalAlignment="Center"/>

                                                    <Button Grid.Column="2" 
                                                            Style="{StaticResource QuantityButtonStyle}"
                                                            Tag="{Binding Id}"
                                                            Click="IncreaseQuantity_Click">
                                                        <FontIcon Glyph="&#xF8AA;" 
                                                                 FontSize="12" 
                                                                 Foreground="#FF6600"/>
                                                    </Button>
                                                </Grid>
                                            </Grid>

                                            <!-- Price and Remove -->
                                            <StackPanel Grid.Column="2" 
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Spacing="8">
                                                <TextBlock Text="{Binding TotalPrice, Converter={StaticResource PriceFormatConverter}}" 
                                                          FontSize="18" 
                                                          FontWeight="Bold" 
                                                          Foreground="#FF6600"
                                                          HorizontalAlignment="Right"/>

                                                <Button Style="{StaticResource RemoveButtonStyle}"
                                                        Tag="{Binding Id}"
                                                        Click="RemoveFromCart_Click"
                                                        HorizontalAlignment="Right">
                                                    <FontIcon Glyph="&#xE74D;" 
                                                             FontSize="16" 
                                                             Foreground="#FF4444"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Order Summary Sidebar -->
                    <Grid x:Name="OrderSummaryPanel" 
                          Grid.Column="1" 
                          Width="300"
                          Margin="20,0,0,0"
                          Visibility="Collapsed">
                        <Border Background="#FFF5E5"
                                BorderBrush="#FFB266"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="20">
                            <StackPanel Spacing="20">
                                <TextBlock Text="Order Summary" 
                                          FontSize="20" 
                                          FontWeight="Bold" 
                                          Foreground="#FF6600"/>

                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="Subtotal" 
                                                   Foreground="#666666"/>
                                        <TextBlock Grid.Column="1" 
                                                   x:Name="SubtotalText"
                                                   FontWeight="SemiBold" 
                                                   Foreground="#FF6600"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="Delivery Fee" 
                                                   Foreground="#666666"/>
                                        <TextBlock Grid.Column="1" 
                                                   x:Name="DeliveryFeeText"
                                                   Text="Calculated at checkout"
                                                   Foreground="#666666"
                                                   FontSize="12"/>
                                    </Grid>

                                    <Border Height="2" 
                                            Background="#FFB266" 
                                            Opacity="0.3"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="Total" 
                                                   FontSize="18" 
                                                   FontWeight="Bold" 
                                                   Foreground="#FF6600"/>
                                        <TextBlock Grid.Column="1" 
                                                   x:Name="TotalText"
                                                   FontSize="18" 
                                                   FontWeight="Bold" 
                                                   Foreground="#FF6600"/>
                                    </Grid>
                                </StackPanel>

                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Content="Proceed to Checkout"
                                        Click="ProceedToCheckout_Click"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <!-- Delivery Form View -->
            <ScrollViewer x:Name="DeliveryView"
              VerticalScrollBarVisibility="Auto"
              Visibility="Collapsed">
                <Grid MaxWidth="600" HorizontalAlignment="Center">
                    <Border Background="#FFF5E5"
                        BorderBrush="#FFB266"
                        BorderThickness="2"
                        CornerRadius="12"
                        Padding="30">
                        <StackPanel Spacing="24">
                            <TextBlock Text="Delivery Details"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#FF6600"/>

                            <TextBlock Text="Where should we deliver your order?"
                                            Foreground="#666666"/>

                            <!-- Address -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Delivery Address *"
                                           Style="{StaticResource DeliveryLabelStyle}"/>
                                <TextBox x:Name="AddressTextBox"
                                         Style="{StaticResource DeliveryInputTextBoxStyle}"
                                         PlaceholderText="e.g., 123 Main St, Barangay, City"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="60"/>
                            </StackPanel>

                            <!-- Location Type -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Location Type *"
                                           Style="{StaticResource DeliveryLabelStyle}"/>
                                <RadioButtons x:Name="LocationRadioButtons"
                                              SelectedIndex="0"
                                              SelectionChanged="LocationRadioButtons_SelectionChanged">
                                    <RadioButton Style="{StaticResource DeliveryRadioButtonStyle}"
                                                 Content="Within Poblacion (₱15 flat rate)"/>
                                    <RadioButton Style="{StaticResource DeliveryRadioButtonStyle}"
                                                 Content="Outside Poblacion (₱25+ based on distance)"/>
                                </RadioButtons>
                            </StackPanel>

                            <!-- Distance -->
                            <StackPanel x:Name="DistancePanel"
                                        Visibility="Collapsed"
                                        Spacing="8">
                                <TextBlock Text="Distance from Poblacion (km) *"
                                           Style="{StaticResource DeliveryLabelStyle}"/>
                                <TextBox x:Name="DistanceTextBox"
                                         Style="{StaticResource DeliveryInputTextBoxStyle}"
                                         PlaceholderText="e.g., 5"
                                         InputScope="Number"/>
                                <TextBlock x:Name="EstimatedFeeText"
                                           Foreground="#FF6600"
                                           FontSize="12"/>
                            </StackPanel>

                            <!-- Delivery Date -->
                            <StackPanel Spacing="8">
                                <StackPanel.Resources>
                                    <SolidColorBrush x:Key="DatePickerPlaceholderForeground" Color="#A67C52"/>
                                    <SolidColorBrush x:Key="DatePickerPlaceholderForegroundPointerOver" Color="#A67C52"/>
                                </StackPanel.Resources>

                                <TextBlock Text="Delivery Date and Time"
                                           Style="{StaticResource DeliveryLabelStyle}"/>
                                <CalendarDatePicker x:Name="DeliveryDatePicker"
                                        Style="{StaticResource DeliveryDatePickerStyle}"
                                        PlaceholderText="Select date" 
                                        RequestedTheme="Light"/>
                                <TimePicker x:Name="DeliveryTimePicker"
                                        Style="{StaticResource DeliveryTimePickerStyle}"/>
                            </StackPanel>

                            <!-- Special Instructions -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Special Instructions (Optional)"
                                           Style="{StaticResource DeliveryLabelStyle}"/>
                                <TextBox x:Name="NotesTextBox"
                                         Style="{StaticResource DeliveryInputTextBoxStyle}"
                                         PlaceholderText="e.g., No spicy, For birthday celebration, etc."
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="80"/>
                            </StackPanel>

                            <!-- Navigation Buttons -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Back to Cart"
                                        Click="BackToCart_Click"/>

                                <Button Grid.Column="1"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Content="Continue to Payment"
                                        Click="ContinueToPayment_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- Payment View -->
            <ScrollViewer x:Name="PaymentView" 
                         VerticalScrollBarVisibility="Auto"
                         Visibility="Collapsed">
                <Grid MaxWidth="600" HorizontalAlignment="Center">
                    <Border Background="#FFF5E5"
                            BorderBrush="#FFB266"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="30">
                        <StackPanel Spacing="24">
                            <TextBlock Text="Payment Method" 
                                      FontSize="28" 
                                      FontWeight="Bold" 
                                      Foreground="#FF6600"/>
                            <TextBlock Text="Choose how you'd like to pay" 
                                      Foreground="#666666"/>

                            <!-- Payment Methods -->
                            <RadioButtons x:Name="PaymentRadioButtons"
                                          SelectedIndex="0"
                                          Header="Payment Method">
                                <RadioButton Content="Cash on Delivery"/>
                                <RadioButton Content="GCash / E-Wallet"/>
                                <RadioButton Content="Reservation / Down Payment (50%)"/>
                            </RadioButtons>

                            <!-- Order Summary -->
                            <Border Background="White"
                                    CornerRadius="8"
                                    Padding="20">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Order Summary" 
                                              FontSize="16" 
                                              FontWeight="Bold" 
                                              Foreground="#FF6600"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="Subtotal"/>
                                        <TextBlock Grid.Column="1" 
                                                   x:Name="PaymentSubtotalText"
                                                   FontWeight="SemiBold" 
                                                   Foreground="#FF6600"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="Delivery Fee"/>
                                        <TextBlock Grid.Column="1" 
                                                   x:Name="PaymentDeliveryFeeText"
                                                   FontWeight="SemiBold" 
                                                   Foreground="#FF6600"/>
                                    </Grid>

                                    <Border Height="1" 
                                            Background="#FFB266" 
                                            Opacity="0.3"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="Total" 
                                                   FontSize="18" 
                                                   FontWeight="Bold" 
                                                   Foreground="#FF6600"/>
                                        <TextBlock Grid.Column="1" 
                                                   x:Name="PaymentTotalText"
                                                   FontSize="18" 
                                                   FontWeight="Bold" 
                                                   Foreground="#FF6600"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Navigation Buttons -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" 
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Back"
                                        Click="BackToDelivery_Click"/>

                                <Button Grid.Column="1" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Content="Place Order"
                                        Click="PlaceOrder_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>