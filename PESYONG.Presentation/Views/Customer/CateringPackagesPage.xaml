<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PESYONG.Presentation.Views.Customer.CateringPackagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PESYONG.Presentation.Views.Customer"
    xmlns:converters="using:PESYONG.ApplicationLogic.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FFFDF5">

    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <converters:PriceFormatConverter x:Key="PriceFormatConverter"/>

        <!-- Card Style with hover effects -->
        <Style x:Key="CateringCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE5CC"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Add to Cart Button Style -->
        <Style x:Key="AddToCartButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF6600"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>

                                    <!-- Hover -->
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="#E65A00"/>
                                        </VisualState.Setters>
                                    </VisualState>

                                    <!-- Click -->
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="#CC4D00"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <ContentPresenter x:Name="contentPresenter"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="#FF6600" 
                CornerRadius="12" 
                Padding="20,15" 
                Margin="20,20,20,0">
            <StackPanel>
                <TextBlock Text="Catering Packages" 
                          FontSize="36" 
                          FontWeight="Bold" 
                          Foreground="White"/>
                <TextBlock Text="Perfect for events, parties, and special occasions" 
                          FontSize="16" 
                          Foreground="#FFE5CC"/>
            </StackPanel>
        </Border>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" 
                      Padding="20"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PackagesItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid Orientation="Horizontal" 
                            MaximumRowsOrColumns="5" 
                            ItemWidth="400"
                            ItemHeight="650"
                            HorizontalAlignment="Stretch"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10">
                            <Border x:Name="CardBorder"
                                    Width="350"
                                    
                                    Style="{StaticResource CateringCardStyle}"
                                    PointerEntered="CardBorder_PointerEntered"
                                    PointerExited="CardBorder_PointerExited">
                                <StackPanel>
                                    <!-- Image -->
                                    <Border Height="200" 
                                            Background="#FFF0E0"
                                            CornerRadius="12,12,0,0">
                                        <Grid>
                                            <Image Source="{Binding ImageSourceString}" 
                                                   Stretch="UniformToFill"/>
                                            <TextBlock Text="No Image" 
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      Foreground="#999999"
                                                      Visibility="{Binding ImageSourceString, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Content -->
                                    <StackPanel Padding="20" Spacing="15">
                                        <!-- Title and Description -->
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="{Binding ProductName}" 
                                                      FontSize="20" 
                                                      FontWeight="Bold" 
                                                      Foreground="#FF6600"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding ProductDescription}" 
                                                      FontSize="14" 
                                                      Foreground="#666666"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Viands List -->
                                        <Border Background="#FFF5E5" 
                                                CornerRadius="8" 
                                                Padding="15">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="Includes:" 
                                                          FontWeight="SemiBold" 
                                                          Foreground="#FF6600"/>

                                                <!-- Show either custom message or list -->
                                                <Grid>
                                                    <TextBlock Text="🔸 Choose any 8 viands from our menu" 
                                                              Foreground="#FF6600"
                                                              FontSize="14"
                                                              Visibility="{Binding MealProductItems.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=0}"/>

                                                    <ItemsControl ItemsSource="{Binding MealProductItems}"
                                                                  Visibility="{Binding MealProductItems.Count, Converter={StaticResource CountToVisibilityConverter}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <FontIcon Glyph="&#xE73E;" 
                                                                             Foreground="#FF6600" 
                                                                             FontSize="12"/>
                                                                    <TextBlock Text="{Binding Meal.MealName}" 
                                                                              Foreground="#FF6600"
                                                                              FontSize="14"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Price -->
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="{Binding ProductBasePrice, Converter={StaticResource PriceFormatConverter}}" 
                                                      FontSize="32" 
                                                      FontWeight="Bold" 
                                                      Foreground="#FF6600"/>
                                        </StackPanel>

                                        <!-- Add to Cart Button -->
                                        <Button Style="{StaticResource AddToCartButtonStyle}"
                                                Tag="{Binding MealProductID}"
                                                Click="AddToCart_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xE7BF;" 
                                                         Foreground="White" 
                                                         FontSize="18"/>
                                                <TextBlock Text="Add to Cart" FontSize="16"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Viand Selection Dialog -->
        <ContentDialog x:Name="ViandSelectionDialog"
                       Title="Select 8 Viands"
                       PrimaryButtonText="Confirm Selection"
                       CloseButtonText="Cancel"
                       PrimaryButtonClick="ViandSelectionDialog_PrimaryButtonClick"
                       DefaultButton="Primary">
            <ContentDialog.Content>
                <StackPanel Width="500" Spacing="20">
                    <TextBlock x:Name="DialogDescription" 
                              TextWrapping="Wrap"
                              Foreground="#666666"/>

                    <TextBlock x:Name="SelectedCountText" 
                              Foreground="#FF6600"
                              FontWeight="SemiBold"
                              FontSize="16"/>

                    <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ViandsGrid">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB"
                                            BorderThickness="2"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"
                                                      Checked="ViandCheckBox_Checked"
                                                      Unchecked="ViandCheckBox_Unchecked"
                                                      Tag="{Binding MealID}"/>

                                            <StackPanel Grid.Column="1">
                                                <Image Source="{Binding ImageSourceString}" 
                                                       Width="100" 
                                                       Height="70" 
                                                       Stretch="UniformToFill"
                                                       Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding MealName}" 
                                                          FontWeight="Medium"
                                                          TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding MealPrice, Converter={StaticResource PriceFormatConverter}}" 
                                                          Foreground="#FF6600"
                                                          FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </ContentDialog.Content>
        </ContentDialog>
    </Grid>
</Page>