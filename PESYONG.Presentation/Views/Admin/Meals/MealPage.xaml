<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PESYONG.Presentation.Views.Admin.Meals.MealPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PESYONG.Presentation.ViewModels.Admin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="AdminMealListViewTemplate" x:DataType="local:MealViewModel">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions> 
                <!--
                <Image Source="{x:Bind ImageSource}" Width="24" Height="24" Stretch="UniformToFill"/>
                -->
                <TextBlock Grid.Column="1"
                     Text="{x:Bind MealName}"
                     x:Phase="1"
                     Style="{ThemeResource BaseTextBlockStyle}"
                     Margin="12,6,0,0"/>
                <TextBlock  Grid.Column="1"
                     Grid.Row="1"
                     Text="{x:Bind DeliveryType}"
                     x:Phase="2"
                     Style="{ThemeResource BodyTextBlockStyle}"
                     Margin="12,0,0,6"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" MaxWidth="360">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            
            <ListView 
                Grid.Row="0"
                SelectionMode="Single" 
                ItemsSource="{x:Bind _viewModel.Meals}"
                ItemTemplate="{StaticResource AdminMealListViewTemplate}"
                SelectionChanged="ListView_SelectionChanged"
                Background="SaddleBrown"/>

            <Button Grid.Row="1" Style="{StaticResource AccentButtonStyle}" Content="Add another meal"/>
        </Grid>

        <StackPanel Grid.Column="1">
            <StackPanel Orientation="Horizontal">
                <!--
                <Image Source="{x:Bind ImageSource}" Width="72" Height="72" Stretch="UniformToFill"/>
                -->
                <StackPanel Margin="12,0,0,0">
                    <TextBlock Text="{x:Bind _viewModel.SelectedMeal.MealID}" FontWeight="SemiBold"/>
                    <TextBox Header="Meal Name" Text="{x:Bind _viewModel.SelectedMeal.MealName, Mode=TwoWay}"/>
                </StackPanel>
            </StackPanel>

            <TextBox Header="Description" Text="{x:Bind _viewModel.SelectedMeal.Description, Mode=TwoWay}" 
             AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>

            <TextBox Header="Price" Text="{x:Bind _viewModel.SelectedMeal.FormattedPrice, Mode=OneWay}" IsReadOnly="True"/>
            <NumberBox Header="Stock Quantity" Value="{x:Bind _viewModel.SelectedMeal.StockQuantity, Mode=TwoWay}"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Bind _viewModel.SelectedMeal.StockStatus}" Foreground="{x:Bind _viewModel.SelectedMeal.AvailabilityColor}"/>
                <TextBlock Text="{x:Bind _viewModel.SelectedMeal.MinMaxOrderText}" FontStyle="Italic"/>
                <TextBlock Text="Low Stock!" Foreground="Red" 
                   Visibility="{x:Bind _viewModel.SelectedMeal.LowStockWarningVisibility}"/>
            </StackPanel>

            <!-- <ComboBox Header="Delivery Type" SelectedItem="{x:Bind SelectedMeal.DeliveryType, Mode=TwoWay}"
              ItemsSource="{x:Bind DeliveryTypes}"/> -->

            <TextBlock Text="{x:Bind _viewModel.SelectedMeal.RelativeCreationTime}" FontSize="10" Foreground="Gray"/>
            <Button x:Name="UpdateMealItemButton" Content="Update Meal Item"  />
        </StackPanel>

    </Grid>
</Page>
