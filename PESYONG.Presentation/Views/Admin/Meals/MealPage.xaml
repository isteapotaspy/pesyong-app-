<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PESYONG.Presentation.Views.Admin.Meals.MealPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PESYONG.Presentation.ViewModels.Admin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    d:DataContext="{d:DesignInstance Type=local:AdminMealListViewModel}"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="AdminMealListViewTemplate" x:DataType="local:MealViewModel">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions> 
                <Image Source="{x:Bind MealImage}" Width="24" Height="24" Stretch="UniformToFill"/>
                <TextBlock Grid.Column="1"
                     Text="{x:Bind MealName}"
                     x:Phase="1"
                     Style="{ThemeResource BaseTextBlockStyle}"
                     Margin="12,6,0,0"/>
                <TextBlock  Grid.Column="1"
                     Grid.Row="1"
                     Text="{x:Bind DeliveryType}"
                     x:Phase="2"
                     Style="{ThemeResource BodyTextBlockStyle}"
                     Margin="12,0,0,6"/>
            </Grid>
        </DataTemplate>

    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" MaxWidth="300">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            
            <ListView 
                Grid.Row="0"
                SelectionMode="Single" 
                ItemsSource="{Binding Meals}"
                ItemTemplate="{StaticResource AdminMealListViewTemplate}"
                SelectionChanged="ListView_SelectionChanged"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                Margin="0,36,0,12"
                CornerRadius="6"/>

            <Button Grid.Row="1" 
                    Style="{StaticResource AccentButtonStyle}" 
                    Content="Add another meal"
                    Margin="0,0,0,24"/>
        </Grid>

        <ScrollViewer Grid.Column="1">
            <StackPanel Orientation="Vertical" Spacing="12" Padding="16"
                DataContext="{Binding SelectedMeal}">

                <!-- Fallback when no meal is selected -->
                <StackPanel x:Name="MainPanel" Visibility="Visible">

                    <!-- Conditional visibility based on SelectedMeal -->
                    <StackPanel.Resources>
                        <x:Boolean x:Key="HasSelectedMeal">True</x:Boolean>
                    </StackPanel.Resources>

                    <!-- Meal Image with Fallback -->
                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" 
                    Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}">
                        <Image x:Name="MealImageControl" Source="{Binding MealImage}" 
                       Width="200" Height="150" Stretch="Uniform"/>
                    </Border>

                    <TextBox Header="Meal ID" 
                             Text="{Binding MealID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText=""/>

                    <TextBox Header="Operator ID"
                             Text="{Binding OperatorID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText=""/>

                    <!-- Meal Name -->
                    <TextBox Header="Meal Name" 
                     Text="{Binding MealName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Enter meal name"/>

                    <!-- Description -->
                    <TextBox Header="Description" 
                     Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="80"
                     PlaceholderText="Enter meal description"/>

                    <!-- Price and Stock Info -->
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <!-- Price -->
                        <TextBox Header="Price" 
                         Text="{Binding MealPrice, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         Width="120"/>

                        <!-- Formatted Price Display -->
                        <TextBlock Text="{Binding FormattedPrice, FallbackValue='$0.00'}" 
                           FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,8" 
                           Foreground="DarkGreen" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Stock Management -->
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <!-- Stock Quantity -->
                        <TextBox Header="Stock Quantity" 
                         Text="{Binding StockQuantity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         Width="120"/>

                        <!-- Min Order Quantity -->
                        <TextBox Header="Min Order" 
                         Text="{Binding MinOrderQuantity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         Width="120"/>
                    </StackPanel>

                    <!-- Stock Status Indicator -->
                    <Border x:Name="StockStatusBorder" Background="LightGray" CornerRadius="4" 
                    Padding="8,4" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding StockStatus, FallbackValue='Loading...'}" 
                               Foreground="White" FontWeight="Bold"/>
                            <TextBlock Text="{Binding StockQuantityText, FallbackValue='0 units'}" 
                               Foreground="White" Opacity="0.9"/>
                        </StackPanel>
                    </Border>

                    <!-- Low Stock Warning -->
                    <Border x:Name="LowStockWarning" Background="#FFFFE6" BorderBrush="#FFFFCC" 
                    BorderThickness="1" CornerRadius="4" Padding="8">
                        <TextBlock Text="⚠ Low stock alert! Replenish inventory soon." 
                           Foreground="#996600" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Delivery Type -->
                    <ComboBox Header="Delivery Type" 
                      SelectedIndex="0"
                      Loaded="DeliveryTypeComboBox_Loaded"
                      SelectionChanged="DeliveryTypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Standard Delivery"/>
                        <ComboBoxItem Content="Express Delivery"/>
                        <ComboBoxItem Content="Self Pickup"/>
                    </ComboBox>

                    <!-- Creation Info -->
                    <TextBlock Text="{Binding RelativeCreationTime, FallbackValue='Recently created'}" 
                       FontSize="12" Foreground="Gray" FontStyle="Italic"/>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button x:Name="DeleteButton" Content="Delete" 
                        Style="{StaticResource DefaultButtonStyle}" Foreground="White"/>

                        <Button x:Name="SaveButton" Content="Save Changes" 
                        Style="{StaticResource AccentButtonStyle}" Foreground="White"/>
                    </StackPanel>

                </StackPanel>

                <!--                 
                <TextBlock x:Name="NoSelectionMessage" Text="Select a meal to edit" 
                   Visibility="Collapsed" FontSize="16" HorizontalAlignment="Center" 
                   VerticalAlignment="Center" Margin="0,100,0,0"/>
                -->
            </StackPanel>
        </ScrollViewer>


    </Grid>
</Page>
